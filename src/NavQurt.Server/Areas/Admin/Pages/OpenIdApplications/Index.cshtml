@page
@model NavQurt.Server.Areas.Admin.Pages.OpenIdApplications.IndexModel
@{
    ViewData["Title"] = "OpenId clients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">OpenId clients</h1>
    <a class="btn btn-primary" asp-page="./Create">Create</a>
</div>

<table class="table table-sm align-middle">
    <thead>
        <tr>
            <th>Client ID</th>
            <th>Display name</th>
            <th>Permissions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Applications)
    {
        <tr>
            <td>@item.ClientId</td>
            <td>@item.DisplayName</td>
            <td><code>@item.Permissions</code></td>
        </tr>
    }
    </tbody>
</table>
