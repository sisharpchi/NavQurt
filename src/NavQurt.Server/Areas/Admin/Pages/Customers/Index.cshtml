@page
@model NavQurt.Server.Areas.Admin.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customerlar";
}

<div class="nq-page-title">
    <div>
        <h1>Customerlar</h1>
        <div class="nq-muted">Order orqali yaratilgan mijozlar.</div>
    </div>
</div>

<div class="nq-card">
    <table class="table nq-table">
        <thead><tr><th>FIO</th><th>Telefon</th><th>Location</th></tr></thead>
        <tbody>
        @foreach (var item in Model.Customers)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.PhoneNumber</td>
                <td>@item.Location</td>
            </tr>
        }
        </tbody>
    </table>
</div>
