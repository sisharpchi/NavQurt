@page
@model NavQurt.Server.Areas.Admin.Pages.Workers.IndexModel
@{
    ViewData["Title"] = "Ishchilar";
}

<div class="nq-page-title">
    <div>
        <h1>Ishchilar</h1>
        <div class="nq-muted">Order uradigan operatorlar.</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="nq-card">
            <form method="post">
                <input asp-for="Input.Id" type="hidden" />
                <div class="mb-3">
                    <label asp-for="Input.FullName" class="form-label">FIO</label>
                    <input asp-for="Input.FullName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Input.PhoneNumber" class="form-label">Telefon</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" />
                </div>
                <div class="form-check mb-3">
                    <input asp-for="Input.IsActive" class="form-check-input" />
                    <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                </div>
                <button class="btn btn-primary" type="submit">Saqlash</button>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="nq-card">
            <table class="table nq-table">
                <thead><tr><th>FIO</th><th>Telefon</th><th>Status</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model.Workers)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.PhoneNumber</td>
                        <td>@(item.IsActive ? "Active" : "Off")</td>
                        <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-route-editId="@item.Id">Edit</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
