@page
@model NavQurt.Server.Areas.Admin.Pages.Ingredients.IndexModel
@{
    ViewData["Title"] = "Ingredientlar";
}

<div class="nq-page-title">
    <div>
        <h1>Ingredientlar</h1>
        <div class="nq-muted">Skladga kiradigan va recipe’da ishlatiladigan mahsulotlar.</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="nq-card">
            <h5 class="mb-3">@(Model.Input.Id > 0 ? "Ingredient edit" : "Yangi ingredient")</h5>
            <form method="post">
                <input asp-for="Input.Id" type="hidden" />
                <div class="nq-form-grid">
                    <div class="span-2">
                        <label asp-for="Input.Title" class="form-label">Nomi</label>
                        <input asp-for="Input.Title" class="form-control" required />
                    </div>
                    <div>
                        <label asp-for="Input.Unit" class="form-label">Unit</label>
                        <input asp-for="Input.Unit" class="form-control" placeholder="kg, dona" required />
                    </div>
                    <div>
                        <label asp-for="Input.MinRemainderLimit" class="form-label">Min qoldiq</label>
                        <input asp-for="Input.MinRemainderLimit" class="form-control" type="number" step="0.001" />
                    </div>
                    <div>
                        <label asp-for="Input.AverageSelfPrice" class="form-label">Self price</label>
                        <input asp-for="Input.AverageSelfPrice" class="form-control" type="number" step="0.01" />
                    </div>
                    <div>
                        <label asp-for="Input.IngredientCategoryId" class="form-label">Category</label>
                        <select asp-for="Input.IngredientCategoryId" class="form-select">
                            <option value="">Yo'q</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id">@category.Title</option>
                            }
                        </select>
                    </div>
                    <div class="span-2 form-check">
                        <input asp-for="Input.IsActive" class="form-check-input" />
                        <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
                <div class="nq-actions mt-3">
                    <button class="btn btn-primary" type="submit">Saqlash</button>
                    <a class="btn btn-light" asp-page="./Index">Tozalash</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="nq-card">
            <table class="table nq-table">
                <thead><tr><th>Nomi</th><th>Category</th><th>Unit</th><th>Min</th><th>Self price</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model.Ingredients)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@Model.GetCategoryTitle(item.IngredientCategoryId)</td>
                        <td>@item.Unit</td>
                        <td>@item.MinRemainderLimit.ToString("N3")</td>
                        <td>@item.AverageSelfPrice.ToString("N0")</td>
                        <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-route-editId="@item.Id">Edit</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
