@page
@model NavQurt.Server.Areas.Admin.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Productlar";
}

<div class="nq-page-title">
    <div>
        <h1>Productlar</h1>
        <div class="nq-muted">Sotiladigan qurut boxlar va combo setlar.</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="row g-3">
    <div class="col-xl-4">
        <div class="nq-card">
            <h5 class="mb-3">@(Model.Input.Id > 0 ? "Product edit" : "Yangi product")</h5>
            <form method="post">
                <input asp-for="Input.Id" type="hidden" />
                <div class="nq-form-grid">
                    <div class="span-2">
                        <label asp-for="Input.Title" class="form-label">Nomi</label>
                        <input asp-for="Input.Title" class="form-control" required />
                    </div>
                    <div>
                        <label asp-for="Input.Price" class="form-label">Sotuv narxi</label>
                        <input asp-for="Input.Price" class="form-control" type="number" step="0.01" required />
                    </div>
                    <div>
                        <label asp-for="Input.SelfPrice" class="form-label">Self price</label>
                        <input asp-for="Input.SelfPrice" class="form-control" type="number" step="0.01" />
                    </div>
                    <div class="span-2">
                        <label asp-for="Input.ProductCategoryId" class="form-label">Category</label>
                        <select asp-for="Input.ProductCategoryId" class="form-select">
                            <option value="">Yo'q</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id">@category.Title</option>
                            }
                        </select>
                    </div>
                    <div class="span-2">
                        <label asp-for="Input.Description" class="form-label">Izoh</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="form-check">
                        <input asp-for="Input.IsActive" class="form-check-input" />
                        <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="Input.IsCombo" class="form-check-input" />
                        <label asp-for="Input.IsCombo" class="form-check-label">Combo</label>
                    </div>
                    <div class="span-2 form-check">
                        <input asp-for="Input.UseOwnRecipeForCombo" class="form-check-input" />
                        <label asp-for="Input.UseOwnRecipeForCombo" class="form-check-label">Combo o‘z recipe’sidan ayrilsin</label>
                    </div>
                </div>

                <hr />
                <h6>Combo itemlar</h6>
                @for (var i = 0; i < Model.Input.ComboItems.Count; i++)
                {
                    <div class="row g-2 mb-2">
                        <div class="col-8">
                            <select asp-for="Input.ComboItems[i].ProductId" class="form-select">
                                <option value="0">Product tanlang</option>
                                @foreach (var product in Model.Products.Where(x => x.Id != Model.Input.Id))
                                {
                                    <option value="@product.Id">@product.Title</option>
                                }
                            </select>
                        </div>
                        <div class="col-4">
                            <input asp-for="Input.ComboItems[i].Quantity" class="form-control" type="number" step="0.001" placeholder="Miqdor" />
                        </div>
                    </div>
                }

                <div class="nq-actions mt-3">
                    <button class="btn btn-primary" type="submit">Saqlash</button>
                    <a class="btn btn-light" asp-page="./Index">Tozalash</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-xl-8">
        <div class="nq-card">
            <table class="table nq-table">
                <thead><tr><th>Nomi</th><th>Category</th><th>Narx</th><th>Type</th><th>Combo</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>@item.Title<br /><span class="nq-muted">@item.Description</span></td>
                        <td>@Model.GetCategoryTitle(item.ProductCategoryId)</td>
                        <td>@item.Price.ToString("N0")</td>
                        <td>@(item.IsCombo ? "Combo" : "Product")</td>
                        <td>@string.Join(", ", item.ComboItems.Select(x => $"{x.ProductTitle} x{x.Quantity:N2}"))</td>
                        <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-route-editId="@item.Id">Edit</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
