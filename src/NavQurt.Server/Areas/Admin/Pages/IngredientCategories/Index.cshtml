@page
@model NavQurt.Server.Areas.Admin.Pages.IngredientCategories.IndexModel
@{
    ViewData["Title"] = "Ingredient category";
}

<div class="nq-page-title">
    <div>
        <h1>Ingredient category</h1>
        <div class="nq-muted">Ingredientlarni guruhlash.</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="nq-card">
            <h5 class="mb-3">@(Model.Input.Id > 0 ? "Category edit" : "Yangi category")</h5>
            <form method="post">
                <input asp-for="Input.Id" type="hidden" />
                <div class="mb-3">
                    <label asp-for="Input.Title" class="form-label">Nomi</label>
                    <input asp-for="Input.Title" class="form-control" required />
                </div>
                <div class="form-check mb-3">
                    <input asp-for="Input.IsActive" class="form-check-input" />
                    <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                </div>
                <div class="nq-actions">
                    <button class="btn btn-primary" type="submit">Saqlash</button>
                    <a class="btn btn-light" asp-page="./Index">Tozalash</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="nq-card">
            <table class="table nq-table">
                <thead><tr><th>Nomi</th><th>Status</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model.Categories)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@(item.IsActive ? "Active" : "Off")</td>
                        <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-route-editId="@item.Id">Edit</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
