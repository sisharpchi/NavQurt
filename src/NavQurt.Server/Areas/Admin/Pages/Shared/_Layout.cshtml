<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/css/fontawesome.css" />
    <link rel="stylesheet" href="~/css/icofont.css" />
    <link rel="stylesheet" href="~/css/themify.css" />
    <link rel="stylesheet" href="~/css/feather-icon.css" />
    <link rel="stylesheet" href="~/css/animate.css" />
    <link rel="stylesheet" href="~/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link id="color" rel="stylesheet" href="~/css/color-1.css" media="screen" />
    <link rel="stylesheet" href="~/css/responsive.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="page-wrapper compact-wrapper" id="pageWrapper">
        <div class="page-main-header">
            <div class="main-header-right row m-0">
                <div class="main-header-left">
                    <div class="logo-wrapper">
                        <a asp-area="Admin" asp-page="/Index"><h4 class="mb-0">NavQurt Admin</h4></a>
                    </div>
                    <div class="toggle-sidebar">
                        <i data-feather="align-center" id="sidebar-toggle"></i>
                    </div>
                </div>
                <div class="nav-right col pull-right right-menu p-0">
                    <ul class="nav-menus">
                        <li class="onhover-dropdown p-0">
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="btn btn-primary-light"><i data-feather="log-out"></i> Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="page-body-wrapper">
            <div class="sidebar-wrapper">
                <div>
                    <div class="logo-wrapper">
                        <a asp-area="Admin" asp-page="/Index"><h4 class="mb-0">NavQurt</h4></a>
                    </div>
                    <nav class="sidebar-main">
                        <ul class="sidebar-links" id="simple-bar">
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Index"><i data-feather="home"></i><span>Dashboard</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Orders/Create"><i data-feather="shopping-cart"></i><span>Order urish</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Orders/Index"><i data-feather="clipboard"></i><span>Orderlar</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Products/Index"><i data-feather="package"></i><span>Productlar</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/ProductCategories/Index"><i data-feather="grid"></i><span>Product category</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Ingredients/Index"><i data-feather="layers"></i><span>Ingredientlar</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/IngredientCategories/Index"><i data-feather="tag"></i><span>Ingredient category</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Recipes/Index"><i data-feather="list"></i><span>Recipe</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Incomes/Index"><i data-feather="download"></i><span>Prixod</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Stocks/Index"><i data-feather="archive"></i><span>Ostatki</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Warehouses/Index"><i data-feather="database"></i><span>Skladlar</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/PaymentMethods/Index"><i data-feather="credit-card"></i><span>Payment</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Customers/Index"><i data-feather="phone"></i><span>Customerlar</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Workers/Index"><i data-feather="user-check"></i><span>Ishchilar</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Users/Index"><i data-feather="users"></i><span>Users</span></a></li>
                            <li class="sidebar-list"><a class="sidebar-link sidebar-title link-nav" asp-area="Admin" asp-page="/Roles/Index"><i data-feather="shield"></i><span>Roles</span></a></li>
                        </ul>
                    </nav>
                </div>
            </div>
            <div class="page-body">
                <div class="container-fluid py-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/jquery-3.5.1.min.js"></script>
    <script src="~/js/icons/feather-icon/feather.min.js"></script>
    <script src="~/js/icons/feather-icon/feather-icon.js"></script>
    <script src="~/js/config.js"></script>
    <script src="~/js/sidebar-menu.js"></script>
    <script src="~/js/bootstrap/popper.min.js"></script>
    <script src="~/js/bootstrap/bootstrap.min.js"></script>
    <script src="~/js/script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
