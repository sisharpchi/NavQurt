@using Microsoft.AspNetCore.Identity
@using NavQurt.Core.Entities
@inject SignInManager<User> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
        <button type="submit" class="btn btn-primary-light">Logout</button>
    </form>
}
else
{
    <a class="btn btn-primary-light" asp-area="Identity" asp-page="/Account/Login">Login</a>
}
