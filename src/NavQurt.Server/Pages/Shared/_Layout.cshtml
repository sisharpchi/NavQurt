@using Microsoft.AspNetCore.Identity
@using NavQurt.Shared.Claims
@inject UserManager<User> UserManager
@{
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
    var displayName = string.Join(" ", new[] { currentUser?.FirstName, currentUser?.LastName }.Where(x => !string.IsNullOrWhiteSpace(x)));
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = User.Identity?.Name ?? "User";
    }

    var isAdminMode = User.HasClaim(CustomClaimTypes.LoginMode, CustomClaimValues.AdminLogin);
}
<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />
    <title>@ViewData["Title"] - NavQurt</title>
    <link rel="icon" href="~/favicon.ico" type="image/x-icon" />
    <link rel="stylesheet" href="~/css/fontawesome.css" />
    <link rel="stylesheet" href="~/css/icofont.css" />
    <link rel="stylesheet" href="~/css/themify.css" />
    <link rel="stylesheet" href="~/css/flag-icon.css" />
    <link rel="stylesheet" href="~/css/feather-icon.css" />
    <link rel="stylesheet" href="~/css/animate.css" />
    <link rel="stylesheet" href="~/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link id="color" rel="stylesheet" href="~/css/color-1.css" media="screen" />
    <link rel="stylesheet" href="~/css/responsive.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="nq-app">
    <div class="page-wrapper compact-wrapper" id="pageWrapper">
        <div class="page-main-header nq-header">
            <div class="main-header-right row m-0">
                <div class="main-header-left nq-header-brand">
                    <div class="logo-wrapper">
                        <a asp-page="/Index" class="nq-brand-link">
                            <span class="nq-brand-mark">NQ</span>
                            <span class="nq-brand-text">NavQurt</span>
                        </a>
                    </div>
                    <div class="toggle-sidebar"><i data-feather="align-center" id="sidebar-toggle"></i></div>
                </div>
                <div class="nav-right col pull-right right-menu p-0">
                    <ul class="nav-menus nq-header-menu">
                        <li><a class="nq-header-link" asp-page="/Orders/Create"><i data-feather="plus-circle"></i><span>Yangi order</span></a></li>
                        <li><a class="nq-header-link" asp-page="/Orders/Index"><i data-feather="clipboard"></i><span>Orderlar</span></a></li>
                        <li><a class="nq-header-link" asp-page="/Products/Index"><i data-feather="package"></i><span>Productlar</span></a></li>
                        <li><a class="nq-header-link" asp-page="/Stocks/Index"><i data-feather="archive"></i><span>Ostatki</span></a></li>
                        @if (isAdminMode)
                        {
                            <li><a class="nq-header-link nq-admin-link" asp-area="Admin" asp-page="/Users/Index"><i data-feather="shield"></i><span>Admin</span></a></li>
                        }
                        <li class="nq-user-area">
                            <span class="nq-user-name">@displayName</span>
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="btn btn-primary-light nq-logout-btn"><i data-feather="log-out"></i><span>Chiqish</span></button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="page-body-wrapper">
            <header class="main-nav nq-sidebar">
                <div class="sidebar nq-sidebar-head">
                    <a asp-page="/Index" class="nq-sidebar-logo">
                        <span class="nq-brand-mark">NQ</span>
                        <span>NavQurt</span>
                    </a>
                </div>
                <nav>
                    <div class="main-navbar">
                        <div class="left-arrow disabled" id="left-arrow"><i data-feather="chevron-left"></i></div>
                        <div id="mainnav">
                            <ul class="nav-menu custom-scrollbar nq-sidebar-menu">
                                <li class="back-btn">
                                    <div class="mobile-back text-end"><span>Back</span><i class="fa fa-angle-right ps-2" aria-hidden="true"></i></div>
                                </li>
                                <li class="sidebar-main-title"><div><h6>Asosiy</h6></div></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Index"><i data-feather="home"></i><span>Dashboard</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Orders/Create"><i data-feather="shopping-cart"></i><span>Order urish</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Orders/Index"><i data-feather="clipboard"></i><span>Orderlar</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Customers/Index"><i data-feather="phone"></i><span>Customerlar</span></a></li>

                                <li class="sidebar-main-title"><div><h6>Menu</h6></div></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Products/Index"><i data-feather="package"></i><span>Productlar</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/ProductCategories/Index"><i data-feather="grid"></i><span>Product category</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Ingredients/Index"><i data-feather="layers"></i><span>Ingredientlar</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/IngredientCategories/Index"><i data-feather="tag"></i><span>Ingredient category</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Recipes/Index"><i data-feather="list"></i><span>Recipe</span></a></li>

                                <li class="sidebar-main-title"><div><h6>Sklad</h6></div></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Incomes/Index"><i data-feather="download"></i><span>Prixod</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Stocks/Index"><i data-feather="archive"></i><span>Ostatki</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Warehouses/Index"><i data-feather="database"></i><span>Skladlar</span></a></li>

                                <li class="sidebar-main-title"><div><h6>Sozlamalar</h6></div></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/PaymentMethods/Index"><i data-feather="credit-card"></i><span>Payment</span></a></li>
                                <li class="dropdown"><a class="nav-link menu-title link-nav nq-side-link" asp-page="/Workers/Index"><i data-feather="user-check"></i><span>Ishchilar</span></a></li>
                            </ul>
                        </div>
                        <div class="right-arrow" id="right-arrow"><i data-feather="chevron-right"></i></div>
                    </div>
                </nav>
            </header>
            <div class="page-body nq-page-body">
                <div class="container-fluid py-4">@RenderBody()</div>
            </div>
        </div>
    </div>
    <script src="~/js/jquery-3.5.1.min.js"></script>
    <script src="~/js/icons/feather-icon/feather.min.js"></script>
    <script src="~/js/icons/feather-icon/feather-icon.js"></script>
    <script src="~/js/config.js"></script>
    <script src="~/js/sidebar-menu.js"></script>
    <script src="~/js/bootstrap/popper.min.js"></script>
    <script src="~/js/bootstrap/bootstrap.min.js"></script>
    <script src="~/js/script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
