@page
@model NavQurt.Server.Pages.Warehouses.IndexModel
@{
    ViewData["Title"] = "Skladlar";
}

<div class="nq-page-title">
    <div><h1>Skladlar</h1></div>
    <a class="btn btn-primary" asp-page="./Create">Yangi</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="nq-card">
    <table class="table nq-table">
        <thead><tr><th>Nomi</th><th>Status</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Title</td>
                <td>@(item.IsActive ? "Active" : "Off")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Detail" asp-route-id="@item.Id">Detail</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>