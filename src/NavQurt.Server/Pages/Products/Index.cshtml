@page
@model NavQurt.Server.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Productlar";
}

<div class="nq-page-title">
    <div>
        <h1>Productlar</h1>
        <div class="nq-muted">@Model.ItemsCount ta product. Sotuv, combo va recipe holatini boshqarish.</div>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Yangi product</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<form method="get" class="nq-card nq-filter-card mb-3">
    <div class="nq-filter-grid">
        <div>
            <label class="form-label" asp-for="Search">Qidirish</label>
            <input class="form-control" asp-for="Search" placeholder="Nomi yoki izoh" />
        </div>
        <div>
            <label class="form-label" asp-for="CategoryId">Category</label>
            <select class="form-select" asp-for="CategoryId">
                <option value="">Hammasi</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id">@category.Title</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label" asp-for="Status">Status</label>
            <select class="form-select" asp-for="Status">
                <option value="">Hammasi</option>
                <option value="true">Active</option>
                <option value="false">Off</option>
            </select>
        </div>
        <div>
            <label class="form-label" asp-for="ProductType">Type</label>
            <select class="form-select" asp-for="ProductType">
                <option value="">Hammasi</option>
                <option value="false">Product</option>
                <option value="true">Combo</option>
            </select>
        </div>
        <div class="nq-filter-check">
            <input class="form-check-input" asp-for="OnlyWithoutRecipe" />
            <label class="form-check-label" asp-for="OnlyWithoutRecipe">Recipe yo'q</label>
        </div>
        <div class="nq-filter-actions">
            <button class="btn btn-outline-primary" type="submit">Search</button>
            <a class="btn btn-light" asp-page="./Index">Tozalash</a>
        </div>
    </div>
</form>

<div class="nq-card">
    <div class="table-responsive">
        <table class="table nq-table">
            <thead>
            <tr>
                <th>Nomi</th>
                <th>Category</th>
                <th>Narx</th>
                <th>Type</th>
                <th>Recipe</th>
                <th>Status</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Title</div>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <span class="nq-muted">@item.Description</span>
                        }
                    </td>
                    <td>@Model.GetCategoryTitle(item)</td>
                    <td>
                        <div>@item.Price.ToString("N0")</div>
                        <span class="nq-muted">Self: @item.SelfPrice.ToString("N0")</span>
                    </td>
                    <td>
                        <span class="nq-status @(item.IsCombo ? "warning" : "info")">@(item.IsCombo ? "Combo" : "Product")</span>
                    </td>
                    <td>
                        @if (item.HasRecipe && item.RecipeId.HasValue)
                        {
                            <a asp-page="/Recipes/Detail" asp-route-id="@item.RecipeId">Recipe</a>
                        }
                        else
                        {
                            <a class="text-danger" asp-page="/Recipes/Create" asp-route-targetType="Product" asp-route-productId="@item.Id">Qo'shish</a>
                        }
                    </td>
                    <td><span class="nq-status @(item.IsActive ? "success" : "muted")">@(item.IsActive ? "Active" : "Off")</span></td>
                    <td class="text-end">
                        <div class="nq-table-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-page="./Detail" asp-route-id="@item.Id">Detail</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
