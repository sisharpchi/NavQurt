@page "{id:int}"
@model NavQurt.Server.Pages.Products.DetailModel
@{
    ViewData["Title"] = "Product detail";
}
<div class="nq-page-title"><div><h1>Product detail</h1></div><a class="btn btn-outline-primary" asp-page="./Index">Orqaga</a></div>
<form method="post" class="nq-card"><div asp-validation-summary="All" class="text-danger"></div>
<div class="nq-form-grid">
    <div class="span-2"><label asp-for="Input.Title" class="form-label">Nomi</label><input asp-for="Input.Title" class="form-control" required /></div>
    <div><label asp-for="Input.Price" class="form-label">Sotuv narxi</label><input asp-for="Input.Price" class="form-control" type="number" step="0.01" required /></div>
    <div><label asp-for="Input.SelfPrice" class="form-label">Self price</label><input asp-for="Input.SelfPrice" class="form-control" type="number" step="0.01" /></div>
    <div class="span-2"><label asp-for="Input.ProductCategoryId" class="form-label">Category</label><select asp-for="Input.ProductCategoryId" class="form-select"><option value="">Yo'q</option>@foreach (var category in Model.Categories) { <option value="@category.Id">@category.Title</option> }</select></div>
    <div class="span-2"><label asp-for="Input.Description" class="form-label">Izoh</label><textarea asp-for="Input.Description" class="form-control" rows="2"></textarea></div>
    <div class="form-check"><input asp-for="Input.IsActive" class="form-check-input" /><label asp-for="Input.IsActive" class="form-check-label">Active</label></div>
    <div class="form-check"><input asp-for="Input.IsCombo" class="form-check-input" /><label asp-for="Input.IsCombo" class="form-check-label">Combo</label></div>
    <div class="span-2 form-check"><input asp-for="Input.UseOwnRecipeForCombo" class="form-check-input" /><label asp-for="Input.UseOwnRecipeForCombo" class="form-check-label">Combo o'z recipe'sidan ayrilsin</label></div>
</div>
<hr />
<h6>Combo itemlar</h6>
@for (var i = 0; i < Model.Input.ComboItems.Count; i++)
{
    <div class="row g-2 mb-2">
        <div class="col-8"><select asp-for="Input.ComboItems[i].ProductId" class="form-select"><option value="0">Product tanlang</option>@foreach (var product in Model.Products.Where(x => x.Id != Model.Id)) { <option value="@product.Id">@product.Title</option> }</select></div>
        <div class="col-4"><input asp-for="Input.ComboItems[i].Quantity" class="form-control" type="number" step="0.001" placeholder="Miqdor" /></div>
    </div>
}
<button class="btn btn-primary mt-3" type="submit">Saqlash</button></form>
