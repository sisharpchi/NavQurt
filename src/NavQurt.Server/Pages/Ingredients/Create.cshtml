@page
@model NavQurt.Server.Pages.Ingredients.CreateModel
@{
    ViewData["Title"] = "Yangi ingredient";
}
<div class="nq-page-title"><div><h1>Yangi ingredient</h1></div><a class="btn btn-outline-primary" asp-page="./Index">Orqaga</a></div>
<form method="post" class="nq-card">
<div asp-validation-summary="All" class="text-danger"></div>
<div class="nq-form-grid">
<div class="span-2"><label asp-for="Input.Title" class="form-label">Nomi</label><input asp-for="Input.Title" class="form-control" required /></div>
<div><label asp-for="Input.Unit" class="form-label">Unit</label><input asp-for="Input.Unit" class="form-control" required /></div>
<div><label asp-for="Input.MinRemainderLimit" class="form-label">Min qoldiq</label><input asp-for="Input.MinRemainderLimit" class="form-control" type="number" step="0.001" /></div>
<div><label asp-for="Input.AverageSelfPrice" class="form-label">Self price</label><input asp-for="Input.AverageSelfPrice" class="form-control" type="number" step="0.01" /></div>
<div><label asp-for="Input.IngredientCategoryId" class="form-label">Category</label><select asp-for="Input.IngredientCategoryId" class="form-select"><option value="">Yo'q</option>@foreach (var category in Model.Categories) { <option value="@category.Id">@category.Title</option> }</select></div>
<div class="span-2 form-check"><input asp-for="Input.IsActive" class="form-check-input" /><label asp-for="Input.IsActive" class="form-check-label">Active</label></div>
</div>
<button class="btn btn-primary mt-3" type="submit">Saqlash</button>
</form>