@page
@model NavQurt.Server.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="nq-page-title">
    <div>
        <h1>NavQurt boshqaruv paneli</h1>
        <div class="nq-muted">Product, ingredient, sklad va orderlar uchun tezkor markaz.</div>
    </div>
    <a class="btn btn-primary" asp-page="/Orders/Create"><i data-feather="shopping-cart"></i> Order urish</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="nq-card nq-stat"><span class="nq-muted">Productlar</span><strong>@Model.ProductCount</strong></div>
    </div>
    <div class="col-md-3">
        <div class="nq-card nq-stat"><span class="nq-muted">Ingredientlar</span><strong>@Model.IngredientCount</strong></div>
    </div>
    <div class="col-md-3">
        <div class="nq-card nq-stat"><span class="nq-muted">Bugungi order</span><strong>@Model.TodayOrders</strong></div>
    </div>
    <div class="col-md-3">
        <div class="nq-card nq-stat"><span class="nq-muted">Bugungi savdo</span><strong>@Model.TodaySales.ToString("N0")</strong></div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="nq-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Oxirgi orderlar</h5>
                <a asp-page="/Orders/Index">Barchasi</a>
            </div>
            <table class="table nq-table">
                <thead><tr><th>Raqam</th><th>Customer</th><th>Summa</th><th>Sana</th></tr></thead>
                <tbody>
                @foreach (var order in Model.RecentOrders)
                {
                    <tr>
                        <td>@order.OrderNumber</td>
                        <td>@order.CustomerFullName<br /><span class="nq-muted">@order.CustomerPhoneNumber</span></td>
                        <td>@order.TotalAmount.ToString("N0")</td>
                        <td>@order.CreatedAt.ToLocalTime().ToString("dd.MM HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="nq-card">
            <h5 class="mb-3">Tezkor bo‘limlar</h5>
            <div class="list-group">
                <a class="list-group-item list-group-item-action" asp-page="/Products/Index">Productlar</a>
                <a class="list-group-item list-group-item-action" asp-page="/Ingredients/Index">Ingredientlar</a>
                <a class="list-group-item list-group-item-action" asp-page="/Incomes/Index">Prixod</a>
                <a class="list-group-item list-group-item-action" asp-page="/Stocks/Index">Ostatki</a>
            </div>
        </div>
    </div>
</div>
