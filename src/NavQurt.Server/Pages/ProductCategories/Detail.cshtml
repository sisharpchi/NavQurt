@page "{id:int}"
@model NavQurt.Server.Pages.ProductCategories.DetailModel
@{
    ViewData["Title"] = "Product category detail";
}

<div class="nq-page-title">
    <div><h1>Product category detail</h1></div>
    <a class="btn btn-outline-primary" asp-page="./Index">Orqaga</a>
</div>

<form method="post" class="nq-card">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Input.Title" class="form-label">Nomi</label>
        <input asp-for="Input.Title" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="Input.ParentCategoryId" class="form-label">Parent</label>
        <select asp-for="Input.ParentCategoryId" class="form-select">
            <option value="">Yo'q</option>
            @foreach (var item in Model.Categories.Where(x => x.Id != Model.Id))
            {
                <option value="@item.Id">@item.Title</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Priority" class="form-label">Priority</label>
        <input asp-for="Input.Priority" class="form-control" type="number" />
    </div>
    <div class="form-check mb-3">
        <input asp-for="Input.IsActive" class="form-check-input" />
        <label asp-for="Input.IsActive" class="form-check-label">Active</label>
    </div>
    <button class="btn btn-primary" type="submit">Saqlash</button>
</form>