@page
@model NavQurt.Server.Pages.Incomes.CreateModel
@{
    ViewData["Title"] = "Yangi prixod";
}
<div class="nq-page-title"><div><h1>Yangi prixod</h1></div><a class="btn btn-outline-primary" asp-page="./Index">Orqaga</a></div>
<form method="post" class="nq-card">
<div asp-validation-summary="All" class="text-danger"></div>
<div class="mb-3"><label asp-for="Input.WarehouseId" class="form-label">Sklad</label><select asp-for="Input.WarehouseId" class="form-select" required>@foreach (var warehouse in Model.Warehouses) { <option value="@warehouse.Id">@warehouse.Title</option> }</select></div>
<div class="mb-3"><label asp-for="Input.Comment" class="form-label">Izoh</label><input asp-for="Input.Comment" class="form-control" /></div>
<h6>Ingredientlar</h6>
@for (var i = 0; i < Model.Input.Items.Count; i++)
{
<div class="row g-2 mb-2"><div class="col-6"><select asp-for="Input.Items[i].IngredientId" class="form-select"><option value="0">Ingredient</option>@foreach (var ingredient in Model.Ingredients) { <option value="@ingredient.Id">@ingredient.Title (@ingredient.Unit)</option> }</select></div><div class="col-3"><input asp-for="Input.Items[i].Quantity" class="form-control" type="number" step="0.001" placeholder="Miqdor" /></div><div class="col-3"><input asp-for="Input.Items[i].Price" class="form-control" type="number" step="0.01" placeholder="Narx" /></div></div>
}
<button class="btn btn-primary mt-2" type="submit">Prixod qilish</button>
</form>