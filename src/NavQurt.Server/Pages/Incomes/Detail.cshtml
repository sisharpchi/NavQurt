@page "{id:int}"
@model NavQurt.Server.Pages.Incomes.DetailModel
@{
    ViewData["Title"] = "Prixod detail";
}

<div class="nq-page-title">
    <div>
        <h1>Prixod #@Model.Income?.Id</h1>
        <div class="nq-muted">Kirim hujjati va ingredientlar ro'yxati.</div>
    </div>
    <a class="btn btn-outline-primary" asp-page="./Index">Orqaga</a>
</div>

@if (Model.Income != null)
{
    <div class="row g-3">
        <div class="col-xl-4">
            <div class="nq-card">
                <h2 class="nq-section-title">Hujjat</h2>
                <dl class="nq-detail-list">
                    <dt>Prixod sanasi</dt>
                    <dd>@Model.Income.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt>Qabul qilingan</dt>
                    <dd>@Model.Income.AcceptedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt>Sklad</dt>
                    <dd>@Model.Income.WarehouseTitle</dd>
                    <dt>Summa</dt>
                    <dd>@Model.Income.TotalAmount.ToString("N0")</dd>
                    <dt>Izoh</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Income.Comment) ? "-" : Model.Income.Comment)</dd>
                </dl>
            </div>
        </div>
        <div class="col-xl-8">
            <div class="nq-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="nq-section-title mb-0">Ingredientlar</h2>
                    <span class="nq-total-chip">@Model.Income.Items.Count ta qator</span>
                </div>
                <div class="table-responsive">
                    <table class="table nq-table">
                        <thead>
                            <tr>
                                <th>Ingredient</th>
                                <th class="text-end">Miqdor</th>
                                <th class="text-end">Narx</th>
                                <th class="text-end">Jami</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Income.Items)
                        {
                            <tr>
                                <td>@item.IngredientTitle</td>
                                <td class="text-end">@item.Quantity.ToString("N3")</td>
                                <td class="text-end">@item.Price.ToString("N0")</td>
                                <td class="text-end">@item.Total.ToString("N0")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
