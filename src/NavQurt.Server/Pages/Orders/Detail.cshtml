@page "{id:int}"
@model NavQurt.Server.Pages.Orders.DetailModel
@{
    ViewData["Title"] = "Order detail";
}
<div class="nq-page-title"><div><h1>Order @Model.Order?.OrderNumber</h1></div><a class="btn btn-outline-primary" asp-page="./Index">Orqaga</a></div>
@if (Model.Order != null)
{
<div class="row g-3"><div class="col-md-4"><div class="nq-card"><dl><dt>Customer</dt><dd>@Model.Order.CustomerFullName<br />@Model.Order.CustomerPhoneNumber<br />@Model.Order.CustomerLocation</dd><dt>Ishchi</dt><dd>@Model.GetWorkerName(Model.Order.WorkerId)</dd><dt>Sklad</dt><dd>@Model.GetWarehouseTitle(Model.Order.WarehouseId)</dd><dt>Jami</dt><dd>@Model.Order.TotalAmount.ToString("N0")</dd><dt>Sana</dt><dd>@Model.Order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd></dl></div></div><div class="col-md-8"><div class="nq-card"><table class="table nq-table"><thead><tr><th>Product</th><th>Miqdor</th><th>Narx</th><th>Jami</th></tr></thead><tbody>@foreach (var item in Model.Order.Items) { <tr><td>@item.ProductTitle</td><td>@item.Quantity.ToString("N2")</td><td>@item.Price.ToString("N0")</td><td>@item.Total.ToString("N0")</td></tr> }</tbody></table></div></div></div>
}