@page
@model NavQurt.Server.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orderlar";
}

<div class="nq-page-title">
    <div>
        <h1>Orderlar</h1>
        <div class="nq-muted">@Model.ItemsCount ta order. Jami: @Model.TotalAmount.ToString("N0")</div>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Order urish</a>
</div>

<form method="get" class="nq-card nq-filter-card mb-3">
    <div class="nq-filter-grid">
        <div>
            <label class="form-label" asp-for="Search">Qidirish</label>
            <input class="form-control" asp-for="Search" placeholder="Order, customer yoki telefon" />
        </div>
        <div>
            <label class="form-label" asp-for="FromDate">Boshlanish</label>
            <input class="form-control" asp-for="FromDate" type="date" />
        </div>
        <div>
            <label class="form-label" asp-for="ToDate">Tugash</label>
            <input class="form-control" asp-for="ToDate" type="date" />
        </div>
        <div>
            <label class="form-label" asp-for="WorkerId">Ishchi</label>
            <select class="form-select" asp-for="WorkerId">
                <option value="">Hammasi</option>
                @foreach (var worker in Model.Workers)
                {
                    <option value="@worker.Id">@worker.FullName</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label" asp-for="WarehouseId">Sklad</label>
            <select class="form-select" asp-for="WarehouseId">
                <option value="">Hammasi</option>
                @foreach (var warehouse in Model.Warehouses)
                {
                    <option value="@warehouse.Id">@warehouse.Title</option>
                }
            </select>
        </div>
        <div class="nq-filter-actions">
            <button class="btn btn-outline-primary" type="submit">Search</button>
            <a class="btn btn-light" asp-page="./Index">Tozalash</a>
        </div>
    </div>
</form>

<div class="nq-card">
    <div class="table-responsive">
        <table class="table nq-table">
            <thead>
            <tr>
                <th>Raqam</th>
                <th>Customer</th>
                <th>Ishchi</th>
                <th>Sklad</th>
                <th>Productlar</th>
                <th>To'lov</th>
                <th>Sana</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Orders)
            {
                <tr>
                    <td><a asp-page="./Detail" asp-route-id="@item.Id">@item.OrderNumber</a></td>
                    <td>
                        <div class="fw-semibold">@item.CustomerFullName</div>
                        <span class="nq-muted">@item.CustomerPhoneNumber @(!string.IsNullOrWhiteSpace(item.CustomerLocation) ? $"- {item.CustomerLocation}" : string.Empty)</span>
                    </td>
                    <td>@Model.GetWorkerName(item)</td>
                    <td>@Model.GetWarehouseTitle(item)</td>
                    <td>@string.Join(", ", item.Items.Select(x => $"{x.ProductTitle} x{x.Quantity:N2}"))</td>
                    <td>
                        <div class="fw-semibold">@item.TotalAmount.ToString("N0")</div>
                        <span class="nq-muted">@string.Join(", ", item.Payments.Select(x => x.PaymentMethodTitle))</span>
                    </td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
