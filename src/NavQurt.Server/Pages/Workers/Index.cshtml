@page
@model NavQurt.Server.Pages.Workers.IndexModel
@{
    ViewData["Title"] = "Ishchilar";
}

<div class="nq-page-title">
    <div><h1>Ishchilar</h1></div>
    <a class="btn btn-primary" asp-page="./Create">Yangi ishchi</a>
</div>
@if (!string.IsNullOrWhiteSpace(Model.Message)) { <div class="alert alert-info">@Model.Message</div> }
<div class="nq-card">
    <table class="table nq-table">
        <thead><tr><th>FIO</th><th>Telefon</th><th>Status</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model.Workers)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.PhoneNumber</td>
                <td>@(item.IsActive ? "Active" : "Off")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Detail" asp-route-id="@item.Id">Detail</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>