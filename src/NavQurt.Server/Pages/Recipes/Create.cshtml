@page
@model NavQurt.Server.Pages.Recipes.CreateModel
@{
    ViewData["Title"] = "Yangi recipe";
}

<div class="nq-page-title">
    <div>
        <h1>Yangi recipe</h1>
        <div class="nq-muted">Product yoki ingredient tarkibini kiriting.</div>
    </div>
    <a class="btn btn-light" asp-page="./Index">Orqaga</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="nq-card">
    <form method="post">
        <div class="nq-form-grid mb-3">
            <div>
                <label class="form-label" asp-for="Input.TargetType">Recipe turi</label>
                <select class="form-select" asp-for="Input.TargetType">
                    <option value="Product">Product</option>
                    <option value="Ingredient">Ingredient</option>
                </select>
            </div>
            <div>
                <label class="form-label" asp-for="Input.PortionYield">Portion yield</label>
                <input class="form-control" asp-for="Input.PortionYield" type="number" step="0.001" min="0.001" />
            </div>
            <div>
                <label class="form-label" asp-for="Input.ProductId">Product</label>
                <select class="form-select" asp-for="Input.ProductId">
                    <option value="">Tanlang</option>
                    @foreach (var product in Model.Products)
                    {
                        <option value="@product.Id">@product.Title</option>
                    }
                </select>
                <div class="nq-muted">Recipe turi Product bo'lsa ishlatiladi.</div>
            </div>
            <div>
                <label class="form-label" asp-for="Input.IngredientId">Ingredient</label>
                <select class="form-select" asp-for="Input.IngredientId">
                    <option value="">Tanlang</option>
                    @foreach (var ingredient in Model.Ingredients)
                    {
                        <option value="@ingredient.Id">@ingredient.Title</option>
                    }
                </select>
                <div class="nq-muted">Recipe turi Ingredient bo'lsa ishlatiladi.</div>
            </div>
        </div>

        <div class="nq-section-title mb-2">Tarkib</div>
        <div class="table-responsive">
            <table class="table nq-table nq-edit-table">
                <thead>
                <tr><th>Ingredient</th><th>Miqdor</th></tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.Input.Items.Count; i++)
                {
                    <tr>
                        <td>
                            <select class="form-select" asp-for="Input.Items[i].IngredientId">
                                <option value="0">Ingredient tanlang</option>
                                @foreach (var ingredient in Model.Ingredients)
                                {
                                    <option value="@ingredient.Id">@ingredient.Title (@ingredient.Unit)</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input class="form-control" asp-for="Input.Items[i].Quantity" type="number" step="0.001" min="0" />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="nq-actions mt-3">
            <button class="btn btn-primary" type="submit">Saqlash</button>
            <a class="btn btn-light" asp-page="./Index">Bekor qilish</a>
        </div>
    </form>
</div>
