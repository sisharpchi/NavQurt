@page
@model NavQurt.Server.Pages.Recipes.IndexModel
@{
    ViewData["Title"] = "Recipe";
}

<div class="nq-page-title">
    <div>
        <h1>Recipe</h1>
        <div class="nq-muted">@Model.ItemsCount ta recipe. Product va yarim tayyor ingredient tarkibi.</div>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Yangi recipe</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<form method="get" class="nq-card nq-filter-card mb-3">
    <div class="nq-filter-grid compact">
        <div>
            <label class="form-label" asp-for="Search">Qidirish</label>
            <input class="form-control" asp-for="Search" placeholder="Target yoki ingredient" />
        </div>
        <div>
            <label class="form-label" asp-for="TargetType">Turi</label>
            <select class="form-select" asp-for="TargetType">
                <option value="">Hammasi</option>
                <option value="Product">Product</option>
                <option value="Ingredient">Ingredient</option>
            </select>
        </div>
        <div class="nq-filter-actions">
            <button class="btn btn-outline-primary" type="submit">Search</button>
            <a class="btn btn-light" asp-page="./Index">Tozalash</a>
        </div>
    </div>
</form>

<div class="nq-card">
    <div class="table-responsive">
        <table class="table nq-table">
            <thead>
            <tr>
                <th>Target</th>
                <th>Turi</th>
                <th>Portion</th>
                <th>Itemlar</th>
                <th>Jami miqdor</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Recipes)
            {
                <tr>
                    <td class="fw-semibold">@item.TargetTitle</td>
                    <td><span class="nq-status @(item.TargetType == "Product" ? "info" : "warning")">@item.TargetType</span></td>
                    <td>@item.PortionYield.ToString("N3")</td>
                    <td>@item.ItemsCount</td>
                    <td>@item.ItemsTotalQuantity.ToString("N3")</td>
                    <td class="text-end">
                        <div class="nq-table-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-page="./Detail" asp-route-id="@item.Id">Detail</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
